# Generated repository staging ignore rules
# Keep the staged repository focused on distributable skill packaging only.

# OS / editor noise
.DS_Store
Thumbs.db
*.swp
*.swo
*.tmp

# Python cache / build noise
__pycache__/
*.pyc

# Local git / tool noise
.git/

# Explicitly excluded live-workspace state at repo root only
/memory/
/reports/
/artifacts/
/.learnings/

# Optional local bootstrap outputs that should not be committed
/bootstrap/out/
/bootstrap/tmp/
/backups/
/dist/
