      {"quality_score": ">= 8.0", "valuation_score": "< 5.0",    "rating": "wishlist_overvalued",       "meaning": "心仪公司池（明显高估）"},
      {"quality_score": "6.5-8.0","valuation_score": ">= 7.0",   "rating": "watchlist_buildable",       "meaning": "观察清单可分批建仓"},
      {"quality_score": "6.5-8.0","valuation_score": "< 7.0",    "rating": "watchlist_quality_only",    "meaning": "观察清单（仅质量过关）"},
      {"quality_score": "< 6.5",  "valuation_score": "any",      "rating": "pass",                       "meaning": "PASS"}
