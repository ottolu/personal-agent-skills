  "dimension_anchors": {
    "_comment": "强制内置完整 6 维锚点表，每个 score 必须配 anchor_used 字段说明所用锚点",
    "business_quality": {
      "weight": 0.20,
      "anchors": [
        {"score": 0,  "description": "明确造假 / 烂生意 / 即将归零",                     "example": "教培被监管归零"},
        {"score": 3,  "description": "普通竞争激烈 / 无定价权 / 低质增长",               "example": "普通家电制造、低端零售"},
        {"score": 5,  "description": "平凡但稳定 / 有一定市场地位",                       "example": "中游制造业龙头"},
        {"score": 7,  "description": "好生意有壁垒 / 长期回报合理 / 可预测现金流",        "example": "苹果、比亚迪"},
        {"score": 10, "description": "极致复利机器（最高分）",                             "example": "茅台 / 可口可乐 / Visa / Moody's"}
      ]
    },
    "management": {
      "weight": 0.15,
      "anchors": [
        {"score": 0,  "description": "造假 / 关联输送 / 毁灭股东价值",         "example": "已立案造假案"},
        {"score": 3,  "description": "能力或诚信存疑 / 信息披露严重不足",       "example": "拼多多治理透明度问题"},
        {"score": 5,  "description": "平稳称职 / 中规中矩",                     "example": "多数国企平均水平"},
        {"score": 7,  "description": "优秀资本配置者 / 长期主义",               "example": "库克、马化腾"},
        {"score": 10, "description": "巴菲特级",                                  "example": "巴菲特、芒格"}
      ]
    },
    "moat": {
      "weight": 0.20,
      "anchors": [
        {"score": 0,  "description": "无壁垒 / 红海竞争",                  "example": "部分中小制造业"},
        {"score": 3,  "description": "有壁垒但持续收窄 / 单一来源",         "example": "平庸消费品"},
        {"score": 5,  "description": "稳定护城河 / 一种来源",                "example": "中等品牌"},
        {"score": 7,  "description": "宽护城河 / 多来源",                   "example": "苹果、招行"},
        {"score": 10, "description": "多重壁垒持续变宽",                     "example": "茅台（品牌+稀缺）、腾讯（网络+切换+生态）"}
      ]
    },
    "financial_quality": {
      "weight": 0.15,
      "anchors": [
        {"score": 0,  "description": "明显造假 / 即将崩溃",                                 "example": "财务造假已暴露"},
        {"score": 3,  "description": "持续疲软 / 多个红旗 / 一票否决预警",                  "example": "万科当前 / 百济未盈利"},
        {"score": 5,  "description": "稳健 / 合规 / 无明显红旗",                            "example": "多数中规中矩公司"},
        {"score": 7,  "description": "优秀质量 / FCF > 净利润 / 低负债",                    "example": "招行、比亚迪"},
        {"score": 10, "description": "堡垒级现金流（最高分）",                               "example": "茅台、苹果、Visa"}
      ]
    },
    "valuation_margin_of_safety": {
      "weight": 0.20,
      "anchors": [
        {"score": 0,  "description": "≥ 2 倍内在价值（严重高估）"},
        {"score": 3,  "description": "10-30% 溢价（贵）"},
        {"score": 5,  "description": "公允价附近（±10%）"},
        {"score": 7,  "description": "20-40% 折价（便宜）"},
        {"score": 10, "description": "≥ 50% 折价（深度低估）"}
      ]
    },
    "risk": {
      "weight": 0.10,
      "anchors": [
        {"score": 0,  "description": "已存在重大致命单点风险",       "example": "监管立案、关键人物突逝、客户崩盘"},
        {"score": 3,  "description": "多个重大风险并存",             "example": "万科 = 2 / 拼多多 = 5"},
        {"score": 5,  "description": "可控",                          "example": "多数公司"},
        {"score": 7,  "description": "低风险",                        "example": "招行"},
        {"score": 10, "description": "反脆弱（黑天鹅有利或免疫）",     "example": "罕见"}
      ]
    }
  },
