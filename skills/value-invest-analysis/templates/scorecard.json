  "computed": {
    "quality_score": {
      "value": null,
      "_comment": "quality_score = (business_quality + management + moat + financial_quality + risk) / 5"
    },
    "valuation_score": {
      "value": null,
      "_comment": "valuation_score = valuation_margin_of_safety.score"
    },
    "weighted_total": {
      "value": null,
      "_comment": "weighted_total = 0.20*biz + 0.15*mgmt + 0.20*moat + 0.15*fin + 0.20*val + 0.10*risk — 仅作参考字段，不再作为决策依据"
    }
